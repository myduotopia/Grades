# =====================================================================
# Frontend environment variables — TEMPLATE
# Copy this file to frontend/.env and fill in the values.
#
# Vite requires the VITE_ prefix for variables exposed to the browser.
# Anything here ends up in the bundled JS — only put PUBLIC values.
# =====================================================================

# --- Supabase (public values) ---------------------------------------
# Find these in: Supabase Console → Settings → API

# Project URL (e.g. https://abcdefgh.supabase.co)
VITE_SUPABASE_URL=

# anon public key (safe to expose; protected by RLS / our backend)
VITE_SUPABASE_ANON_KEY=

# --- Backend --------------------------------------------------------
# Grades backend URL. Local dev: 8000 (8080 is taken by Duotopia)
VITE_API_BASE_URL=http://localhost:8000

# --- App config -----------------------------------------------------
VITE_APP_ENV=development

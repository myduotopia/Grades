# =====================================================================
# Backend environment variables — TEMPLATE
# Copy this file to backend/.env and fill in the values from Supabase.
# .env is gitignored; .env.example is committed.
# =====================================================================

# --- Database -------------------------------------------------------
# Supabase Postgres connection string. Pick the right pooler for the host:
#
#   Local dev / GitHub Actions (single-shot CLI):
#     Session pooler (port 5432). Long-lived script-style connections.
#
#   Vercel serverless (per-request connection-per-function):
#     Transaction pooler (port 6543). Required — Vercel each request a new
#     connection, the Transaction pooler keeps Postgres from running out of
#     slots. Direct connection (no pooler) WILL exhaust connection limits.
#
# Find both URIs in: Supabase Console → Connect button (top of dashboard)
#   → "Direct" tab → Session pooler / Transaction pooler
# Format: postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:<5432|6543>/postgres
DATABASE_URL=

# --- Supabase API ---------------------------------------------------
# Find these in: Supabase Console → Settings → API

# Project URL — public, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# service_role secret — BACKEND ONLY, never expose to frontend
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth -----------------------------------------------------------
# JWT secret used to verify bearer tokens from the frontend.
# Find in: Supabase Console → Settings → API → "JWT Settings" → "JWT Secret"
SUPABASE_JWT_SECRET=

# --- CORS -----------------------------------------------------------
# Comma-separated list of allowed frontend origins.
# Local dev default: http://localhost:5000 (Vite configured to use 5000 to
# avoid conflict with sibling projects that use Vite's default 5173)
CORS_ALLOWED_ORIGINS=http://localhost:5000

# --- App config -----------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO

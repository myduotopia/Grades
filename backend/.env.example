# =====================================================================
# Backend environment variables — TEMPLATE
# Copy this file to backend/.env and fill in the values from Supabase.
# .env is gitignored; .env.example is committed.
# =====================================================================

# --- Database -------------------------------------------------------
# Supabase Postgres connection string via Session pooler (port 5432, IPv4).
# Find it in: Supabase Console → Connect button (top of dashboard)
#   → "Direct" tab → Connection Method = "Session pooler" → copy the URI
# Format: postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres
#
# Why Session pooler (not Transaction pooler)?
# Cloud Run connects to external services over IPv4. Supabase's Transaction
# pooler is IPv6-only by default (paid IPv4 add-on required). Session pooler
# is IPv4 by default and works for our scale. Direct connection (5432, no
# pooling) would exhaust Postgres connections from Cloud Run's many instances.
DATABASE_URL=

# --- Supabase API ---------------------------------------------------
# Find these in: Supabase Console → Settings → API

# Project URL — public, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# service_role secret — BACKEND ONLY, never expose to frontend
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth -----------------------------------------------------------
# JWT secret used to verify bearer tokens from the frontend.
# Find in: Supabase Console → Settings → API → "JWT Settings" → "JWT Secret"
SUPABASE_JWT_SECRET=

# --- CORS -----------------------------------------------------------
# Comma-separated list of allowed frontend origins.
# Local dev default: http://localhost:5000 (Vite configured to use 5000 to
# avoid conflict with sibling projects that use Vite's default 5173)
CORS_ALLOWED_ORIGINS=http://localhost:5000

# --- App config -----------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
